<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/log_border"
    android:layout_marginLeft="18dp"
    android:layout_marginRight="18dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="12dp"
    android:padding="14dp">

    <!-- Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/labelButton7"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="95dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#E65100"
            android:text="Height 1 Depth 1"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/labelButton8"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="95dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#E65100"
            android:text="Height 1 Depth 2"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/labelButton9"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="95dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#F57C00"
            android:text="Height 2 Depth 1"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/labelButton10"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="95dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#F57C00"
            android:text="Height 2 Depth 2"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/labelButton11"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="95dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#FB8C00"
            android:text="Height 3 Depth 1"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/labelButton12"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="95dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#FB8C00"
            android:text="Height 3 Depth 2"
            android:textSize="14sp"/>
    </LinearLayout>

</LinearLayout>