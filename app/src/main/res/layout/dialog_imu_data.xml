<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="0dp">

    <!-- Header with title and close button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#052A64"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="IMU Data Monitor"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/closeImuDataDialog"
            android:layout_width="80dp"
            android:layout_height="50dp"
            android:text="×"
            android:textSize="24sp"
            android:backgroundTint="#E65C61"
            android:padding="0dp"/>
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="@drawable/log_border"
        android:layout_margin="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="5dp">

            <!-- Row 1: IMU1 and IMU2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- IMU1 Column (Left) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="5dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Left Foot (IMU 1)"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#052A64"
                        android:gravity="center"
                        android:paddingBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Roll Angle"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:paddingBottom="2dp"/>
                    <TextView
                        android:id="@+id/imu1Roll"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rectangle"
                        android:backgroundTint="#E3F2FD"
                        android:padding="6dp"
                        android:text="0.0 deg"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>



                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Battery"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:paddingBottom="2dp"/>
                    <TextView
                        android:id="@+id/imu1Battery"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rectangle"
                        android:backgroundTint="#E3F2FD"
                        android:padding="6dp"
                        android:text="0%"
                        android:textSize="16sp"/>
                </LinearLayout>

                <!-- IMU2 Column (Right) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="5dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Right Foot (IMU 2)"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#052A64"
                        android:gravity="center"
                        android:paddingBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Roll Angle"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:paddingBottom="2dp"/>
                    <TextView
                        android:id="@+id/imu2Roll"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rectangle"
                        android:backgroundTint="#E3F2FD"
                        android:padding="6dp"
                        android:text="0.0 deg"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>



                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Battery"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:paddingBottom="2dp"/>
                    <TextView
                        android:id="@+id/imu2Battery"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rectangle"
                        android:backgroundTint="#E3F2FD"
                        android:padding="6dp"
                        android:text="0%"
                        android:textSize="16sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Divider between rows -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#3F51B5"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Row 2: IMU3 and IMU4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- IMU3 Column (Left) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="5dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Left Thigh (IMU 3)"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#052A64"
                        android:gravity="center"
                        android:paddingBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Roll Angle"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:paddingBottom="2dp"/>
                    <TextView
                        android:id="@+id/imu3Roll"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rectangle"
                        android:backgroundTint="#E3F2FD"
                        android:padding="6dp"
                        android:text="0.0 deg"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>


                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Battery"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:paddingBottom="2dp"/>
                    <TextView
                        android:id="@+id/imu3Battery"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rectangle"
                        android:backgroundTint="#E3F2FD"
                        android:padding="6dp"
                        android:text="0%"
                        android:textSize="16sp"/>
                </LinearLayout>

                <!-- IMU4 Column (Right) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="5dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Right thigh (IMU 4)"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#052A64"
                        android:gravity="center"
                        android:paddingBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Roll Angle"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:paddingBottom="2dp"/>
                    <TextView
                        android:id="@+id/imu4Roll"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rectangle"
                        android:backgroundTint="#E3F2FD"
                        android:padding="6dp"
                        android:text="0.0 deg"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>



                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Battery"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:paddingBottom="2dp"/>
                    <TextView
                        android:id="@+id/imu4Battery"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rectangle"
                        android:backgroundTint="#E3F2FD"
                        android:padding="6dp"
                        android:text="0%"
                        android:textSize="16sp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>